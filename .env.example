# Bot 配置
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
TELEGRAM_BOT_USERNAME=your_bot_username

# 数据库配置
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blackholebot

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 安全配置
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=your_fernet_key_here
SECRET_KEY=your_secret_key_here

# Web 配置
WEB_HOST=0.0.0.0
WEB_PORT=8000
# WEB_DOMAIN=https://your-domain.com  # 可选：如果有域名，取消注释并填写

# 限流配置
TRANSFER_LIMIT_PER_SESSION=500
TRANSFER_COOLDOWN_MINUTES=3

# 合集配置
MAX_MEDIA_PER_COLLECTION=1000
MEDIA_PER_PAGE=10
PRIVATE_CHANNEL=-1001234567890  # 私有频道ID，用于发送合集内容

# JWT 配置
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 日志配置
LOG_LEVEL=INFO
